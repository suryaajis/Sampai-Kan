# Server
PORT=3000
NODE_ENV=development

# Session
SESSION_SECRET=change-this-to-a-strong-random-value

# Mailer (optional - emails will be skipped if empty)
MAIL_SERVICE=hotmail
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@sampaikan.com

# Database (used in production via DATABASE_URL, otherwise see config/config.json)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
