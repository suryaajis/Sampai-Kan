<% const pageTitle = item.name %>
<%- include('../partials/header', { pageTitle }) %>
<%- include('../partials/nav-customer') %>

<section class="max-w-5xl mx-auto px-4 md:px-6 py-8 flex-1 w-full">
  <a href="/customer" class="inline-flex items-center gap-2 text-gray-600 hover:text-primary mb-4">
    <i class="fa-solid fa-arrow-left"></i> Kembali ke menu
  </a>

  <div class="bg-white rounded-3xl shadow-sm overflow-hidden grid md:grid-cols-2">
    <div class="aspect-[4/3] md:aspect-auto bg-gray-100">
      <img src="<%= item.imageUrl %>" alt="<%= item.name %>" class="w-full h-full object-cover" onerror="this.src='https://via.placeholder.com/600x400?text=Menu'">
    </div>
    <div class="p-6 md:p-8 flex flex-col">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-xs bg-primary-light text-primary px-2 py-0.5 rounded-full font-medium"><%= item.Category ? item.Category.name : '' %></span>
        <span class="text-xs text-gray-500"><i class="fa-solid fa-star text-yellow-500"></i> 4.<%= 5 + (item.id % 5) %> · <%= 100 + item.id * 7 %>+ terjual</span>
      </div>
      <h1 class="text-2xl md:text-3xl font-bold"><%= item.name %></h1>
      <p class="text-gray-600 mt-2 flex-1"><%= item.description %></p>

      <div class="text-3xl font-extrabold text-primary mt-6"><%= formatPrice(item.price) %></div>

      <form action="/customer/cart/add/<%= item.id %>" method="POST" class="mt-6 space-y-4">
        <div class="flex items-center gap-4">
          <label class="text-sm font-medium text-gray-700">Jumlah</label>
          <div class="flex items-center border border-gray-200 rounded-full">
            <button type="button" onclick="adjustQty(-1)" class="w-10 h-10 flex items-center justify-center text-primary hover:bg-primary-light rounded-l-full">
              <i class="fa-solid fa-minus"></i>
            </button>
            <input id="qty" name="quantity" type="number" min="1" value="1" class="w-14 text-center font-semibold bg-transparent outline-none">
            <button type="button" onclick="adjustQty(1)" class="w-10 h-10 flex items-center justify-center text-primary hover:bg-primary-light rounded-r-full">
              <i class="fa-solid fa-plus"></i>
            </button>
          </div>
        </div>

        <input type="hidden" name="redirect" value="/customer/cart">
        <button type="submit" class="w-full btn-primary py-3 rounded-xl font-semibold">
          <i class="fa-solid fa-cart-plus mr-2"></i>Tambahkan ke Keranjang
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  function adjustQty(delta) {
    const input = document.getElementById('qty')
    const next = Math.max(1, (parseInt(input.value) || 1) + delta)
    input.value = next
  }
</script>

<%- include('../partials/footer') %>
