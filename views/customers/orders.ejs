<% const pageTitle = 'Riwayat Pesanan' %>
<%- include('../partials/header', { pageTitle }) %>
<%- include('../partials/nav-customer') %>

<section class="max-w-5xl mx-auto px-4 md:px-6 py-8 flex-1 w-full">
  <h1 class="text-2xl md:text-3xl font-bold mb-6">Riwayat Pesanan</h1>

  <% if (orders.length === 0) { %>
    <div class="bg-white rounded-3xl p-12 text-center">
      <div class="w-24 h-24 mx-auto bg-primary-light rounded-full flex items-center justify-center text-primary">
        <i class="fa-solid fa-receipt text-4xl"></i>
      </div>
      <h3 class="text-xl font-semibold mt-4">Belum ada pesanan</h3>
      <p class="text-gray-500 mt-1">Mulai pesan menu favoritmu sekarang!</p>
      <a href="/customer" class="inline-block mt-6 px-6 py-3 btn-primary rounded-full font-semibold">
        <i class="fa-solid fa-utensils mr-2"></i>Jelajah Menu
      </a>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% orders.forEach(order => { const meta = statusLabel(order.status) %>
        <a href="/customer/orders/<%= order.id %>" class="block bg-white rounded-2xl p-5 hover:shadow-md transition">
          <div class="flex items-start justify-between gap-3 mb-3">
            <div>
              <div class="flex items-center gap-2 flex-wrap">
                <span class="font-bold">#<%= String(order.id).padStart(5, '0') %></span>
                <span class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-0.5 rounded-full <%= meta.color %>">
                  <i class="fa-solid <%= meta.icon %>"></i> <%= meta.label %>
                </span>
              </div>
              <p class="text-xs text-gray-500 mt-1"><%= formatDate(order.createdAt) %></p>
            </div>
            <div class="text-right">
              <div class="font-bold text-primary"><%= formatPrice(order.total) %></div>
              <div class="text-xs text-gray-500"><%= order.OrderItems.length %> item</div>
            </div>
          </div>
          <div class="flex gap-2 overflow-x-auto no-scrollbar">
            <% order.OrderItems.slice(0, 4).forEach(oi => { %>
              <div class="text-xs bg-gray-100 rounded-full px-3 py-1 whitespace-nowrap"><%= oi.quantity %>× <%= oi.name %></div>
            <% }) %>
            <% if (order.OrderItems.length > 4) { %>
              <div class="text-xs bg-gray-100 rounded-full px-3 py-1 whitespace-nowrap">+<%= order.OrderItems.length - 4 %> lainnya</div>
            <% } %>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
