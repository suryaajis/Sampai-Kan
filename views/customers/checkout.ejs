<% const pageTitle = 'Checkout' %>
<%- include('../partials/header', { pageTitle }) %>
<%- include('../partials/nav-customer') %>

<section class="max-w-6xl mx-auto px-4 md:px-6 py-8 flex-1 w-full">
  <div class="flex items-center gap-3 mb-6">
    <a href="/customer/cart" class="text-gray-600 hover:text-primary"><i class="fa-solid fa-arrow-left"></i></a>
    <h1 class="text-2xl md:text-3xl font-bold">Checkout</h1>
  </div>

  <form action="/customer/checkout" method="POST" class="grid lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-4">
      <!-- Delivery Details -->
      <div class="bg-white rounded-2xl p-6">
        <h2 class="font-bold text-lg mb-4 flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-primary-light text-primary flex items-center justify-center"><i class="fa-solid fa-map-location-dot"></i></div>
          Detail Pengiriman
        </h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Alamat Pengiriman</label>
            <textarea name="address" rows="2" required placeholder="Alamat lengkap tujuan"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"><%= customer ? customer.address : '' %></textarea>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">No. Telepon Penerima</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-sm">+62</span>
              <input type="text" name="phone" required value="<%= customer ? customer.phone : '' %>"
                     class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none">
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Catatan untuk Driver (opsional)</label>
            <input type="text" name="notes" placeholder="Contoh: Titip di security, jangan di-bel"
                   class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none">
          </div>
        </div>
      </div>

      <!-- Payment Method -->
      <div class="bg-white rounded-2xl p-6">
        <h2 class="font-bold text-lg mb-4 flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-primary-light text-primary flex items-center justify-center"><i class="fa-solid fa-wallet"></i></div>
          Metode Pembayaran
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <% const methods = [
            { id:'cash', name:'Tunai (COD)', icon:'fa-money-bill-wave' },
            { id:'ewallet', name:'E-Wallet', icon:'fa-mobile-screen-button' },
            { id:'transfer', name:'Transfer Bank', icon:'fa-building-columns' }
          ] %>
          <% methods.forEach((m, i) => { %>
            <label class="relative cursor-pointer">
              <input type="radio" name="paymentMethod" value="<%= m.id %>" class="peer sr-only" <%= i === 0 ? 'checked' : '' %>>
              <div class="border-2 border-gray-200 rounded-xl p-4 text-center peer-checked:border-primary peer-checked:bg-primary-light">
                <i class="fa-solid <%= m.icon %> text-2xl text-primary"></i>
                <div class="font-medium text-sm mt-2"><%= m.name %></div>
              </div>
            </label>
          <% }) %>
        </div>
      </div>

      <!-- Items Summary -->
      <div class="bg-white rounded-2xl p-6">
        <h2 class="font-bold text-lg mb-4 flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-primary-light text-primary flex items-center justify-center"><i class="fa-solid fa-utensils"></i></div>
          Pesananmu (<%= totals.itemCount %> item)
        </h2>
        <div class="divide-y divide-gray-100">
          <% cart.forEach(item => { %>
            <div class="py-3 flex items-center gap-3">
              <div class="w-14 h-14 bg-gray-100 rounded-lg overflow-hidden shrink-0">
                <img src="<%= item.imageUrl %>" alt="<%= item.name %>" class="w-full h-full object-cover" onerror="this.src='https://via.placeholder.com/100?text=Menu'">
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-medium text-sm truncate"><%= item.name %></div>
                <div class="text-xs text-gray-500"><%= item.quantity %> × <%= formatPrice(item.price) %></div>
              </div>
              <div class="font-semibold text-sm"><%= formatPrice(item.price * item.quantity) %></div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="lg:col-span-1">
      <div class="bg-white rounded-2xl p-6 sticky top-24">
        <h3 class="font-bold text-lg mb-4">Ringkasan Pembayaran</h3>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-gray-600">Subtotal</span><span><%= formatPrice(totals.subtotal) %></span></div>
          <div class="flex justify-between"><span class="text-gray-600">Ongkos Kirim</span><span><%= formatPrice(totals.deliveryFee) %></span></div>
          <hr class="border-gray-100 my-2">
          <div class="flex justify-between"><span class="font-semibold">Total Pembayaran</span><span class="font-bold text-primary text-lg"><%= formatPrice(totals.total) %></span></div>
        </div>
        <button type="submit" class="mt-6 w-full btn-primary py-3 rounded-xl font-semibold">
          <i class="fa-solid fa-circle-check mr-2"></i>Buat Pesanan
        </button>
        <p class="text-xs text-gray-500 text-center mt-3">Dengan memesan, Anda setuju dengan syarat &amp; ketentuan kami.</p>
      </div>
    </div>
  </form>
</section>

<%- include('../partials/footer') %>
