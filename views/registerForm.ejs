<% const pageTitle = 'Daftar' %>
<%- include('partials/header', { pageTitle }) %>
<%- include('partials/navbar') %>

<section class="flex-1 py-12 md:py-16 px-4">
  <div class="max-w-5xl mx-auto grid md:grid-cols-2 bg-white rounded-3xl shadow-xl overflow-hidden">
    <div class="hidden md:flex hero-gradient text-white p-10 flex-col justify-between">
      <div>
        <div class="flex items-center gap-2 mb-6">
          <div class="w-12 h-12 rounded-full bg-white/20 flex items-center justify-center">
            <i class="fa-solid fa-motorcycle text-white text-xl"></i>
          </div>
          <span class="text-2xl font-bold">Sampai-Kan</span>
        </div>
        <h2 class="text-3xl font-extrabold leading-tight mb-3">Bergabung Sekarang!</h2>
        <p class="opacity-90 mb-6">Daftar gratis dan nikmati kemudahan memesan atau antar makanan.</p>
        <ul class="space-y-3 text-sm">
          <li class="flex items-center gap-3"><i class="fa-solid fa-check-circle text-yellow-300"></i> Gratis tanpa biaya registrasi</li>
          <li class="flex items-center gap-3"><i class="fa-solid fa-check-circle text-yellow-300"></i> Promo menarik setiap hari</li>
          <li class="flex items-center gap-3"><i class="fa-solid fa-check-circle text-yellow-300"></i> Pengiriman cepat &amp; aman</li>
        </ul>
      </div>
    </div>

    <div class="p-8 md:p-10">
      <h1 class="text-3xl font-bold mb-2">Daftar Akun</h1>
      <p class="text-gray-500 mb-6">Sudah punya akun? <a href="/login" class="text-primary font-semibold hover:underline">Masuk di sini</a></p>

      <% if (errors && errors.length) { %>
        <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl p-4 mb-4">
          <div class="font-semibold mb-1"><i class="fa-solid fa-triangle-exclamation mr-1"></i> Ada kesalahan</div>
          <ul class="text-sm list-disc list-inside">
            <% errors.forEach(e => { %><li><%= e %></li><% }) %>
          </ul>
        </div>
      <% } %>

      <form action="/register" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Nama Lengkap</label>
          <input type="text" name="fullName" required value="<%= old.fullName || '' %>" placeholder="John Doe"
                 class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none">
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input type="email" name="email" required value="<%= old.email || '' %>" placeholder="nama@email.com"
                 class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none">
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">No. Telepon</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-sm">+62</span>
              <input type="text" name="phone" required value="<%= old.phone || '' %>" placeholder="812xxxxxxxx"
                     class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none">
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <input type="password" name="password" required placeholder="Min. 6 karakter"
                   class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none">
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Alamat</label>
          <textarea name="address" rows="2" required placeholder="Alamat lengkap pengiriman"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"><%= old.address || '' %></textarea>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Daftar sebagai</label>
          <div class="grid grid-cols-2 gap-3">
            <label class="relative cursor-pointer">
              <input type="radio" name="role" value="Customer" class="peer sr-only" <%= old.role === 'Customer' ? 'checked' : '' %> required>
              <div class="border-2 border-gray-200 rounded-xl p-4 text-center peer-checked:border-primary peer-checked:bg-primary-light">
                <i class="fa-solid fa-user text-2xl text-primary"></i>
                <div class="font-semibold mt-2">Customer</div>
              </div>
            </label>
            <label class="relative cursor-pointer">
              <input type="radio" name="role" value="Driver" class="peer sr-only" <%= old.role === 'Driver' ? 'checked' : '' %> required>
              <div class="border-2 border-gray-200 rounded-xl p-4 text-center peer-checked:border-brand-green peer-checked:bg-green-50">
                <i class="fa-solid fa-motorcycle text-2xl text-brand-green"></i>
                <div class="font-semibold mt-2">Driver</div>
              </div>
            </label>
          </div>
        </div>

        <button type="submit" class="w-full btn-primary py-3 rounded-xl font-semibold">
          <i class="fa-solid fa-user-plus mr-2"></i>Daftar Sekarang
        </button>

        <p class="text-xs text-gray-500 text-center mt-3">
          Dengan mendaftar, Anda menyetujui <a href="#" class="text-primary hover:underline">Syarat &amp; Ketentuan</a> kami.
        </p>
      </form>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
