<% const pageTitle = item ? 'Edit Menu' : 'Tambah Menu' %>
<%- include('../partials/header', { pageTitle }) %>
<%- include('../partials/nav-merchant') %>

<section class="max-w-3xl mx-auto px-4 md:px-6 py-8 flex-1 w-full">
  <a href="/merchant/items" class="inline-flex items-center gap-2 text-gray-600 hover:text-brand-amber mb-4">
    <i class="fa-solid fa-arrow-left"></i> Kembali ke daftar menu
  </a>

  <div class="bg-white rounded-3xl p-6 md:p-8">
    <h1 class="text-2xl font-bold mb-6"><%= item ? 'Edit Menu' : 'Tambah Menu Baru' %></h1>

    <% if (errors && errors.length) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl p-4 mb-4">
        <ul class="text-sm list-disc list-inside">
          <% errors.forEach(e => { %><li><%= e %></li><% }) %>
        </ul>
      </div>
    <% } %>

    <form action="<%= item && item.id ? '/merchant/items/' + item.id + '?_method=PUT' : '/merchant/items' %>" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Nama Menu</label>
        <input type="text" name="name" required value="<%= item ? item.name : '' %>"
               class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-amber focus:ring-2 focus:ring-brand-amber/20 focus:outline-none">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Deskripsi</label>
        <textarea name="description" rows="3"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-amber focus:ring-2 focus:ring-brand-amber/20 focus:outline-none"><%= item ? item.description : '' %></textarea>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Harga (Rp)</label>
          <input type="number" name="price" required min="0" step="500" value="<%= item ? item.price : '' %>"
                 class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-amber focus:ring-2 focus:ring-brand-amber/20 focus:outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Kategori</label>
          <select name="CategoryId" required
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-amber focus:ring-2 focus:ring-brand-amber/20 focus:outline-none">
            <option value="">Pilih kategori</option>
            <% categories.forEach(c => { %>
              <option value="<%= c.id %>" <%= item && String(item.CategoryId) === String(c.id) ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">URL Gambar</label>
        <input type="url" name="imageUrl" value="<%= item ? item.imageUrl : '' %>" placeholder="https://..."
               class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-amber focus:ring-2 focus:ring-brand-amber/20 focus:outline-none">
        <% if (item && item.imageUrl) { %>
          <img src="<%= item.imageUrl %>" class="mt-3 w-32 h-32 object-cover rounded-xl border" onerror="this.style.display='none'">
        <% } %>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="bg-brand-amber text-white px-6 py-3 rounded-xl font-semibold hover:opacity-90">
          <i class="fa-solid fa-floppy-disk mr-2"></i><%= item ? 'Simpan Perubahan' : 'Tambah Menu' %>
        </button>
        <a href="/merchant/items" class="px-6 py-3 rounded-xl border border-gray-300 text-gray-700 font-semibold hover:bg-gray-50">Batal</a>
      </div>
    </form>
  </div>
</section>

<%- include('../partials/footer') %>
