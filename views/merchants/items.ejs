<% const pageTitle = 'Kelola Menu' %>
<%- include('../partials/header', { pageTitle }) %>
<%- include('../partials/nav-merchant') %>

<section class="max-w-5xl mx-auto px-4 md:px-6 py-8 flex-1 w-full">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl md:text-3xl font-bold">Kelola Menu</h1>
    <a href="/merchant/items/new" class="bg-brand-amber text-white px-5 py-2.5 rounded-xl font-semibold hover:opacity-90 flex items-center gap-2">
      <i class="fa-solid fa-plus"></i> Tambah Menu
    </a>
  </div>

  <% if (items.length === 0) { %>
    <div class="bg-white rounded-3xl p-12 text-center">
      <div class="w-20 h-20 mx-auto bg-amber-50 rounded-full flex items-center justify-center text-3xl mb-4">🍽️</div>
      <h3 class="font-semibold text-lg">Belum ada menu</h3>
      <p class="text-gray-500 text-sm mt-1">Mulai tambahkan menu untuk tokomu</p>
      <a href="/merchant/items/new" class="mt-4 inline-block bg-brand-amber text-white px-6 py-2.5 rounded-xl font-semibold hover:opacity-90">Tambah Sekarang</a>
    </div>
  <% } else { %>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      <% items.forEach(item => { %>
        <div class="bg-white rounded-2xl overflow-hidden hover:shadow-md transition">
          <img src="<%= item.imageUrl %>" alt="<%= item.name %>" class="w-full h-40 object-cover"
               onerror="this.src='https://placehold.co/400x300/f3f4f6/9ca3af?text=No+Image'">
          <div class="p-4">
            <div class="text-xs text-brand-amber font-semibold mb-1"><%= item.Category ? item.Category.name : '' %></div>
            <h3 class="font-bold text-base leading-tight mb-1"><%= item.name %></h3>
            <p class="text-xs text-gray-500 line-clamp-2 mb-2"><%= item.description %></p>
            <div class="font-bold text-primary mb-3"><%= formatPrice(item.price) %></div>
            <div class="flex gap-2">
              <a href="/merchant/items/<%= item.id %>/edit" class="flex-1 text-center border border-brand-amber text-brand-amber py-1.5 rounded-lg text-sm font-medium hover:bg-amber-50">
                <i class="fa-solid fa-pen mr-1"></i>Edit
              </a>
              <form action="/merchant/items/<%= item.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Hapus menu ini?')" class="flex-1">
                <button class="w-full border border-red-400 text-red-500 py-1.5 rounded-lg text-sm font-medium hover:bg-red-50">
                  <i class="fa-solid fa-trash mr-1"></i>Hapus
                </button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
