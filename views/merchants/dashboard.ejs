<% const pageTitle = 'Dashboard Toko' %>
<%- include('../partials/header', { pageTitle }) %>
<%- include('../partials/nav-merchant') %>

<section class="max-w-6xl mx-auto px-4 md:px-6 py-8 flex-1 w-full">
  <!-- Header -->
  <div class="bg-gradient-to-r from-brand-amber to-yellow-400 rounded-3xl p-6 md:p-8 text-white mb-6">
    <div class="flex items-center justify-between flex-wrap gap-4">
      <div>
        <div class="flex items-center gap-3">
          <% if (store.logoUrl) { %>
            <img src="<%= store.logoUrl %>" alt="logo" class="w-14 h-14 rounded-2xl object-cover bg-white/20">
          <% } else { %>
            <div class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center text-2xl">🏪</div>
          <% } %>
          <div>
            <h1 class="text-2xl md:text-3xl font-bold"><%= store.name %></h1>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-xs px-2 py-0.5 rounded-full font-semibold <%= store.isOpen ? 'bg-green-500' : 'bg-red-400' %>">
                <%= store.isOpen ? 'BUKA' : 'TUTUP' %>
              </span>
              <span class="opacity-80 text-sm"><%= session.fullName %></span>
            </div>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-3 gap-3 md:gap-5">
        <div class="bg-white/15 backdrop-blur px-4 py-3 rounded-2xl text-center">
          <div class="text-xs opacity-80">Menunggu</div>
          <div class="text-2xl font-bold"><%= pendingCount %></div>
        </div>
        <div class="bg-white/15 backdrop-blur px-4 py-3 rounded-2xl text-center">
          <div class="text-xs opacity-80">Aktif</div>
          <div class="text-2xl font-bold"><%= preparingCount %></div>
        </div>
        <div class="bg-white/15 backdrop-blur px-4 py-3 rounded-2xl text-center">
          <div class="text-xs opacity-80">Selesai</div>
          <div class="text-2xl font-bold"><%= totalDelivered %></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick actions -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
    <a href="/merchant/orders" class="bg-white rounded-2xl p-4 flex flex-col items-center gap-2 hover:shadow-md transition text-center">
      <div class="w-12 h-12 bg-amber-100 text-brand-amber rounded-xl flex items-center justify-center text-xl">
        <i class="fa-solid fa-receipt"></i>
      </div>
      <span class="font-semibold text-sm">Kelola Pesanan</span>
      <% if (pendingCount > 0) { %>
        <span class="text-xs bg-red-500 text-white px-2 py-0.5 rounded-full font-bold"><%= pendingCount %> baru</span>
      <% } %>
    </a>
    <a href="/merchant/items/new" class="bg-white rounded-2xl p-4 flex flex-col items-center gap-2 hover:shadow-md transition text-center">
      <div class="w-12 h-12 bg-green-100 text-green-600 rounded-xl flex items-center justify-center text-xl">
        <i class="fa-solid fa-plus"></i>
      </div>
      <span class="font-semibold text-sm">Tambah Menu</span>
    </a>
    <a href="/merchant/items" class="bg-white rounded-2xl p-4 flex flex-col items-center gap-2 hover:shadow-md transition text-center">
      <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center text-xl">
        <i class="fa-solid fa-utensils"></i>
      </div>
      <span class="font-semibold text-sm">Daftar Menu</span>
    </a>
    <a href="/merchant/store" class="bg-white rounded-2xl p-4 flex flex-col items-center gap-2 hover:shadow-md transition text-center">
      <div class="w-12 h-12 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center text-xl">
        <i class="fa-solid fa-gear"></i>
      </div>
      <span class="font-semibold text-sm">Pengaturan Toko</span>
    </a>
  </div>

  <!-- Recent orders -->
  <div>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold">Pesanan Masuk</h2>
      <a href="/merchant/orders" class="text-sm text-brand-amber font-medium hover:underline">Lihat semua</a>
    </div>

    <% if (recentOrders.length === 0) { %>
      <div class="bg-white rounded-3xl p-12 text-center">
        <div class="w-20 h-20 mx-auto bg-amber-50 rounded-full flex items-center justify-center text-brand-amber text-3xl mb-4">
          <i class="fa-solid fa-inbox"></i>
        </div>
        <h3 class="font-semibold text-lg">Belum ada pesanan</h3>
        <p class="text-gray-500 mt-1 text-sm">Pesanan dari customer akan muncul di sini</p>
      </div>
    <% } else { %>
      <div class="space-y-3">
        <% recentOrders.forEach(order => { const m = statusLabel(order.status) %>
          <div class="bg-white rounded-2xl p-5">
            <div class="flex items-start justify-between flex-wrap gap-2 mb-3">
              <div>
                <div class="flex items-center gap-2">
                  <span class="font-bold">#<%= String(order.id).padStart(5, '0') %></span>
                  <span class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-0.5 rounded-full <%= m.color %>">
                    <i class="fa-solid <%= m.icon %>"></i> <%= m.label %>
                  </span>
                </div>
                <p class="text-xs text-gray-500 mt-1"><%= order.Customer.fullName %> · <%= formatDate(order.createdAt) %></p>
              </div>
              <div class="text-right">
                <div class="font-bold text-primary"><%= formatPrice(order.total) %></div>
                <div class="text-xs text-gray-500"><%= order.OrderItems.length %> item</div>
              </div>
            </div>
            <% if (order.status === 'pending') { %>
              <div class="flex gap-2">
                <form action="/merchant/orders/<%= order.id %>/confirm" method="POST" class="flex-1">
                  <button class="w-full bg-brand-green text-white py-2 rounded-xl text-sm font-semibold hover:bg-green-700">
                    <i class="fa-solid fa-check mr-1"></i>Terima
                  </button>
                </form>
                <form action="/merchant/orders/<%= order.id %>/reject" method="POST" class="flex-1">
                  <button class="w-full bg-red-500 text-white py-2 rounded-xl text-sm font-semibold hover:bg-red-600">
                    <i class="fa-solid fa-times mr-1"></i>Tolak
                  </button>
                </form>
              </div>
            <% } else { %>
              <a href="/merchant/orders/<%= order.id %>" class="text-sm text-brand-amber font-medium hover:underline">
                Lihat detail <i class="fa-solid fa-arrow-right ml-1"></i>
              </a>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
