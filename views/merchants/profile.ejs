<% const pageTitle = 'Profil Merchant' %>
<%- include('../partials/header', { pageTitle }) %>
<%- include('../partials/nav-merchant') %>

<section class="max-w-4xl mx-auto px-4 md:px-6 py-8 flex-1 w-full">
  <h1 class="text-2xl md:text-3xl font-bold mb-6">Profil Merchant</h1>

  <div class="grid lg:grid-cols-3 gap-6">
    <div class="lg:col-span-1">
      <div class="bg-white rounded-2xl p-6 text-center">
        <img src="<%= merchant.profileUrl %>" alt="avatar"
             class="w-24 h-24 mx-auto rounded-full object-cover bg-gray-100"
             onerror="this.src='https://api.dicebear.com/7.x/initials/svg?seed=' + encodeURIComponent('<%= merchant.fullName %>')">
        <h3 class="font-bold text-lg mt-3"><%= merchant.fullName %></h3>
        <p class="text-sm text-gray-500"><%= merchant.email %></p>
        <div class="mt-4 bg-amber-50 rounded-xl p-3">
          <div class="text-xs text-gray-500">Toko</div>
          <div class="font-semibold text-brand-amber"><%= session.storeName || '-' %></div>
        </div>
      </div>
    </div>

    <div class="lg:col-span-2">
      <div class="bg-white rounded-2xl p-6">
        <h2 class="font-bold text-lg mb-4">Edit Profil</h2>
        <% if (errors && errors.length) { %>
          <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl p-4 mb-4">
            <ul class="text-sm list-disc list-inside">
              <% errors.forEach(e => { %><li><%= e %></li><% }) %>
            </ul>
          </div>
        <% } %>
        <form action="/merchant/profile" method="POST" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Nama Lengkap</label>
            <input type="text" name="fullName" required value="<%= merchant.fullName %>"
                   class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-amber focus:ring-2 focus:ring-brand-amber/20 focus:outline-none">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input type="email" name="email" required value="<%= merchant.email %>"
                   class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-amber focus:ring-2 focus:ring-brand-amber/20 focus:outline-none">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">No. Telepon</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-sm">+62</span>
              <input type="text" name="phone" value="<%= merchant.phone || '' %>"
                     class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:border-brand-amber focus:ring-2 focus:ring-brand-amber/20 focus:outline-none">
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">URL Foto Profil</label>
            <input type="url" name="profileUrl" value="<%= merchant.profileUrl || '' %>"
                   class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-amber focus:ring-2 focus:ring-brand-amber/20 focus:outline-none">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Password Baru <span class="text-gray-400 text-xs">(kosongkan jika tidak ingin mengubah)</span></label>
            <input type="password" name="password" placeholder="Min. 6 karakter"
                   class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-amber focus:ring-2 focus:ring-brand-amber/20 focus:outline-none">
          </div>
          <button type="submit" class="bg-brand-amber text-white px-6 py-3 rounded-xl font-semibold hover:opacity-90">
            <i class="fa-solid fa-floppy-disk mr-2"></i>Simpan Perubahan
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
