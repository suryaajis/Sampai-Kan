<% const pageTitle = 'Detail Pesanan #' + order.id %>
<%- include('../partials/header', { pageTitle }) %>
<%- include('../partials/nav-merchant') %>

<% const m = statusLabel(order.status) %>

<section class="max-w-4xl mx-auto px-4 md:px-6 py-8 flex-1 w-full">
  <a href="/merchant/orders" class="inline-flex items-center gap-2 text-gray-600 hover:text-brand-amber mb-4">
    <i class="fa-solid fa-arrow-left"></i> Kembali ke pesanan
  </a>

  <div class="bg-white rounded-3xl p-6 mb-4">
    <div class="flex items-start justify-between flex-wrap gap-3">
      <div>
        <div class="flex items-center gap-2">
          <span class="font-bold text-xl">#<%= String(order.id).padStart(5, '0') %></span>
          <span class="inline-flex items-center gap-1 text-xs font-semibold px-2.5 py-0.5 rounded-full <%= m.color %>">
            <i class="fa-solid <%= m.icon %>"></i> <%= m.label %>
          </span>
        </div>
        <p class="text-sm text-gray-500 mt-1"><%= formatDate(order.createdAt) %></p>
      </div>
      <% if (order.status === 'pending') { %>
        <div class="flex gap-2">
          <form action="/merchant/orders/<%= order.id %>/confirm" method="POST">
            <button class="bg-brand-green text-white px-5 py-2 rounded-xl text-sm font-semibold hover:bg-green-700">
              <i class="fa-solid fa-check mr-1"></i>Terima
            </button>
          </form>
          <form action="/merchant/orders/<%= order.id %>/reject" method="POST">
            <button class="border-2 border-red-400 text-red-500 px-5 py-2 rounded-xl text-sm font-semibold hover:bg-red-50">
              <i class="fa-solid fa-times mr-1"></i>Tolak
            </button>
          </form>
        </div>
      <% } %>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-4 mb-4">
    <div class="bg-white rounded-2xl p-6">
      <h3 class="font-bold mb-3"><i class="fa-solid fa-user text-brand-amber mr-2"></i>Customer</h3>
      <div class="space-y-2 text-sm">
        <div><strong><%= order.Customer.fullName %></strong></div>
        <div><i class="fa-solid fa-phone text-gray-400 mr-2"></i>+62<%= order.Customer.phone %></div>
        <div><i class="fa-solid fa-envelope text-gray-400 mr-2"></i><%= order.Customer.email %></div>
      </div>
    </div>
    <div class="bg-white rounded-2xl p-6">
      <h3 class="font-bold mb-3"><i class="fa-solid fa-location-dot text-brand-amber mr-2"></i>Pengiriman</h3>
      <div class="space-y-2 text-sm">
        <div><%= order.address %></div>
        <div><i class="fa-solid fa-phone text-gray-400 mr-2"></i>+62<%= order.phone %></div>
        <% if (order.notes) { %>
          <div class="bg-amber-50 border border-amber-200 rounded-lg p-2 text-xs mt-2">
            <i class="fa-solid fa-note-sticky text-amber-600 mr-1"></i><strong>Catatan:</strong> <%= order.notes %>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <% if (order.Driver) { %>
    <div class="bg-white rounded-2xl p-6 mb-4">
      <h3 class="font-bold mb-3"><i class="fa-solid fa-motorcycle text-brand-green mr-2"></i>Driver</h3>
      <div class="text-sm space-y-1">
        <div><strong><%= order.Driver.fullName %></strong></div>
        <div><i class="fa-solid fa-phone text-gray-400 mr-2"></i>+62<%= order.Driver.phone %></div>
      </div>
    </div>
  <% } %>

  <div class="bg-white rounded-2xl p-6">
    <h3 class="font-bold mb-3"><i class="fa-solid fa-utensils text-brand-amber mr-2"></i>Item Pesanan</h3>
    <div class="divide-y divide-gray-100">
      <% order.OrderItems.forEach(oi => { %>
        <div class="py-2 flex items-center justify-between">
          <div>
            <div class="font-medium"><%= oi.name %></div>
            <div class="text-xs text-gray-500"><%= oi.quantity %> × <%= formatPrice(oi.price) %></div>
          </div>
          <div class="font-semibold"><%= formatPrice(oi.subtotal) %></div>
        </div>
      <% }) %>
    </div>
    <hr class="border-gray-100 my-3">
    <div class="flex justify-between text-sm"><span class="text-gray-600">Subtotal</span><span><%= formatPrice(order.subtotal) %></span></div>
    <div class="flex justify-between text-sm"><span class="text-gray-600">Ongkos Kirim</span><span><%= formatPrice(order.deliveryFee) %></span></div>
    <div class="flex justify-between font-bold mt-2"><span>Total</span><span class="text-primary"><%= formatPrice(order.total) %></span></div>
    <div class="text-xs text-gray-500 mt-1">Metode: <strong class="uppercase"><%= order.paymentMethod %></strong></div>
  </div>
</section>

<%- include('../partials/footer') %>
