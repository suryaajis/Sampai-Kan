<% const pageTitle = 'Pesanan Toko' %>
<%- include('../partials/header', { pageTitle }) %>
<%- include('../partials/nav-merchant') %>

<section class="max-w-5xl mx-auto px-4 md:px-6 py-8 flex-1 w-full">
  <h1 class="text-2xl md:text-3xl font-bold mb-6">Pesanan</h1>

  <!-- Tabs -->
  <div class="flex gap-2 mb-6">
    <a href="/merchant/orders?tab=active"
       class="px-5 py-2.5 rounded-xl font-semibold text-sm transition <%= tab === 'active' ? 'bg-brand-amber text-white' : 'bg-white text-gray-600 hover:bg-amber-50' %>">
      Aktif
    </a>
    <a href="/merchant/orders?tab=history"
       class="px-5 py-2.5 rounded-xl font-semibold text-sm transition <%= tab === 'history' ? 'bg-brand-amber text-white' : 'bg-white text-gray-600 hover:bg-amber-50' %>">
      Riwayat
    </a>
  </div>

  <% if (orders.length === 0) { %>
    <div class="bg-white rounded-3xl p-12 text-center">
      <div class="w-20 h-20 mx-auto bg-amber-50 rounded-full flex items-center justify-center text-brand-amber text-3xl mb-4">
        <i class="fa-solid fa-inbox"></i>
      </div>
      <h3 class="font-semibold text-lg">Tidak ada pesanan</h3>
    </div>
  <% } else { %>
    <div class="space-y-3">
      <% orders.forEach(order => { const m = statusLabel(order.status) %>
        <div class="bg-white rounded-2xl p-5">
          <div class="flex items-start justify-between flex-wrap gap-3 mb-3">
            <div>
              <div class="flex items-center gap-2">
                <a href="/merchant/orders/<%= order.id %>" class="font-bold hover:text-brand-amber">#<%= String(order.id).padStart(5, '0') %></a>
                <span class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-0.5 rounded-full <%= m.color %>">
                  <i class="fa-solid <%= m.icon %>"></i> <%= m.label %>
                </span>
              </div>
              <p class="text-xs text-gray-500 mt-1">
                <i class="fa-solid fa-user mr-1"></i><%= order.Customer.fullName %> ·
                <%= formatDate(order.createdAt) %>
              </p>
            </div>
            <div class="text-right">
              <div class="font-bold text-primary"><%= formatPrice(order.total) %></div>
              <div class="text-xs text-gray-500"><%= order.OrderItems.length %> item · <span class="uppercase"><%= order.paymentMethod %></span></div>
            </div>
          </div>

          <div class="text-sm text-gray-600 mb-3 line-clamp-1">
            <i class="fa-solid fa-location-dot text-gray-400 mr-1"></i><%= order.address %>
          </div>

          <% if (order.status === 'pending') { %>
            <div class="flex gap-2">
              <form action="/merchant/orders/<%= order.id %>/confirm" method="POST" class="flex-1">
                <button class="w-full bg-brand-green text-white py-2.5 rounded-xl text-sm font-semibold hover:bg-green-700">
                  <i class="fa-solid fa-check mr-1"></i>Terima Pesanan
                </button>
              </form>
              <form action="/merchant/orders/<%= order.id %>/reject" method="POST" class="flex-1">
                <button class="w-full border-2 border-red-400 text-red-500 py-2.5 rounded-xl text-sm font-semibold hover:bg-red-50">
                  <i class="fa-solid fa-times mr-1"></i>Tolak
                </button>
              </form>
            </div>
          <% } else { %>
            <a href="/merchant/orders/<%= order.id %>" class="inline-flex items-center gap-1 text-sm text-brand-amber font-medium hover:underline">
              Lihat detail <i class="fa-solid fa-arrow-right"></i>
            </a>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
