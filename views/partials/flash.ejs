<% if ((flashSuccess && flashSuccess.length) || (flashError && flashError.length)) { %>
  <div class="fixed top-20 right-4 z-50 space-y-2 max-w-sm">
    <% flashSuccess && flashSuccess.forEach(function(msg) { %>
      <div class="flash-toast flex items-start gap-3 bg-white border-l-4 border-brand-green shadow-lg rounded-lg p-4">
        <i class="fa-solid fa-circle-check text-brand-green text-xl mt-0.5"></i>
        <p class="text-sm text-gray-700 flex-1"><%= msg %></p>
      </div>
    <% }) %>
    <% flashError && flashError.forEach(function(msg) { %>
      <div class="flash-toast flex items-start gap-3 bg-white border-l-4 border-red-500 shadow-lg rounded-lg p-4">
        <i class="fa-solid fa-circle-xmark text-red-500 text-xl mt-0.5"></i>
        <p class="text-sm text-gray-700 flex-1"><%= msg %></p>
      </div>
    <% }) %>
  </div>
<% } %>
