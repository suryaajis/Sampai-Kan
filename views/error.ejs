<% const pageTitle = 'Error ' + code %>
<%- include('partials/header', { pageTitle }) %>
<%- include('partials/navbar') %>

<section class="flex-1 flex items-center justify-center py-16 px-4">
  <div class="max-w-md w-full text-center bg-white p-10 rounded-3xl shadow-sm">
    <div class="text-8xl font-extrabold text-primary mb-2"><%= code %></div>
    <h1 class="text-2xl font-bold mb-2">
      <%= code === 404 ? 'Halaman Tidak Ditemukan' : 'Terjadi Kesalahan' %>
    </h1>
    <p class="text-gray-500 mb-6"><%= message %></p>
    <a href="/" class="inline-block px-6 py-3 btn-primary rounded-full font-semibold">
      <i class="fa-solid fa-home mr-2"></i>Kembali ke Beranda
    </a>
  </div>
</section>

<%- include('partials/footer') %>
