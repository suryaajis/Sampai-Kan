<% const pageTitle = 'Beranda' %>
<%- include('partials/header', { pageTitle }) %>
<%- include('partials/navbar') %>

<!-- Hero Section -->
<section class="hero-gradient text-white">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-16 md:py-24 grid md:grid-cols-2 gap-10 items-center">
    <div>
      <span class="inline-block px-3 py-1 bg-white/20 rounded-full text-sm font-medium mb-4">
        <i class="fa-solid fa-bolt mr-1"></i> Pengiriman Cepat & Aman
      </span>
      <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-4">
        Lapar? <br>Biar Kami <span class="text-yellow-300">Antar-Kan!</span>
      </h1>
      <p class="text-lg md:text-xl opacity-90 mb-8">
        Ribuan menu makanan &amp; minuman favoritmu, siap diantar dalam hitungan menit.
        Pesan sekarang, nikmati di rumah!
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/register" class="px-8 py-3 bg-white text-primary rounded-full font-bold text-center hover:shadow-lg transition">
          <i class="fa-solid fa-user-plus mr-2"></i>Daftar Gratis
        </a>
        <a href="/login" class="px-8 py-3 bg-white/20 backdrop-blur border-2 border-white/40 rounded-full font-bold text-center hover:bg-white/30 transition">
          <i class="fa-solid fa-right-to-bracket mr-2"></i>Masuk
        </a>
      </div>
      <div class="flex items-center gap-6 mt-8">
        <div>
          <div class="text-3xl font-bold">500+</div>
          <div class="text-sm opacity-80">Menu Tersedia</div>
        </div>
        <div>
          <div class="text-3xl font-bold">30 mnt</div>
          <div class="text-sm opacity-80">Rata-rata Antar</div>
        </div>
        <div>
          <div class="text-3xl font-bold">4.9<i class="fa-solid fa-star text-yellow-300 ml-1 text-xl"></i></div>
          <div class="text-sm opacity-80">Rating Pelanggan</div>
        </div>
      </div>
    </div>
    <div class="relative hidden md:block">
      <div class="absolute -top-8 -right-8 w-72 h-72 bg-yellow-300/30 rounded-full blur-3xl"></div>
      <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=800&h=600&fit=crop"
           alt="Hero food" class="relative rounded-3xl shadow-2xl w-full object-cover aspect-[4/3]">
      <div class="absolute -bottom-6 -left-6 bg-white text-gray-800 rounded-2xl shadow-xl p-4 flex items-center gap-3">
        <div class="w-12 h-12 bg-brand-green rounded-full flex items-center justify-center">
          <i class="fa-solid fa-check text-white text-lg"></i>
        </div>
        <div>
          <div class="font-bold">Pesanan Sampai!</div>
          <div class="text-xs text-gray-500">Nikmati makananmu 🎉</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Categories -->
<section id="categories" class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="flex items-end justify-between mb-8">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold">Kategori Populer</h2>
        <p class="text-gray-500 mt-2">Pilih kategori favoritmu</p>
      </div>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      <% const categoryIcons = { 'Makanan':'fa-bowl-food', 'Minuman':'fa-mug-hot', 'Snack':'fa-cookie-bite', 'Dessert':'fa-ice-cream' } %>
      <% const categoryColors = { 'Makanan':'bg-orange-100 text-orange-600', 'Minuman':'bg-blue-100 text-blue-600', 'Snack':'bg-yellow-100 text-yellow-600', 'Dessert':'bg-pink-100 text-pink-600' } %>
      <% categories.forEach(cat => { %>
        <a href="/login" class="menu-card bg-white border border-gray-100 rounded-2xl p-6 text-center hover:border-primary">
          <div class="w-16 h-16 mx-auto rounded-2xl <%= categoryColors[cat.name] || 'bg-primary-light text-primary' %> flex items-center justify-center text-2xl">
            <i class="fa-solid <%= categoryIcons[cat.name] || 'fa-utensils' %>"></i>
          </div>
          <h3 class="font-semibold mt-3"><%= cat.name %></h3>
          <p class="text-xs text-gray-500 mt-1">Lihat menu</p>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- Featured Menu -->
<section id="featured" class="py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="flex items-end justify-between mb-8">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold">Menu Populer</h2>
        <p class="text-gray-500 mt-2">Pilihan terbaik untuk kamu</p>
      </div>
      <a href="/login" class="text-primary font-medium hover:underline hidden md:inline">Lihat semua <i class="fa-solid fa-arrow-right ml-1"></i></a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
      <% featured.forEach(item => { %>
        <div class="menu-card bg-white rounded-2xl overflow-hidden border border-gray-100">
          <div class="relative aspect-[4/3] bg-gray-100 overflow-hidden">
            <img src="<%= item.imageUrl %>" alt="<%= item.name %>" class="w-full h-full object-cover" onerror="this.src='https://via.placeholder.com/400x300?text=Menu'">
            <span class="absolute top-3 left-3 bg-white/90 text-xs font-semibold px-2 py-1 rounded-full text-gray-700">
              <i class="fa-solid fa-star text-yellow-500"></i> 4.<%= 5 + (item.id % 5) %>
            </span>
          </div>
          <div class="p-4">
            <div class="text-xs text-primary font-medium"><%= item.Category ? item.Category.name : '' %></div>
            <h3 class="font-semibold mt-1 line-clamp-2"><%= item.name %></h3>
            <p class="text-xs text-gray-500 line-clamp-2 mt-1"><%= item.description %></p>
            <div class="flex items-center justify-between mt-3">
              <span class="font-bold text-primary"><%= formatPrice(item.price) %></span>
              <a href="/login" class="w-9 h-9 bg-primary rounded-full flex items-center justify-center text-white hover:bg-primary-dark">
                <i class="fa-solid fa-plus"></i>
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- How It Works -->
<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold">Cara Kerja Sampai-Kan</h2>
      <p class="text-gray-500 mt-2">Mudah, cepat, tinggal pesan!</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-20 h-20 mx-auto bg-primary-light rounded-full flex items-center justify-center text-primary text-3xl"><i class="fa-solid fa-list"></i></div>
        <h3 class="font-bold text-lg mt-4">1. Pilih Menu</h3>
        <p class="text-gray-500 mt-2">Jelajahi ratusan menu favoritmu, dari makanan berat hingga dessert.</p>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 mx-auto bg-primary-light rounded-full flex items-center justify-center text-primary text-3xl"><i class="fa-solid fa-cart-shopping"></i></div>
        <h3 class="font-bold text-lg mt-4">2. Checkout</h3>
        <p class="text-gray-500 mt-2">Masukkan ke keranjang, isi alamat, dan pilih metode pembayaran.</p>
      </div>
      <div class="text-center">
        <div class="w-20 h-20 mx-auto bg-primary-light rounded-full flex items-center justify-center text-primary text-3xl"><i class="fa-solid fa-motorcycle"></i></div>
        <h3 class="font-bold text-lg mt-4">3. Pesanan Datang</h3>
        <p class="text-gray-500 mt-2">Driver kami akan mengantarkan langsung ke depan pintumu.</p>
      </div>
    </div>
  </div>
</section>

<!-- Driver + Merchant CTA -->
<section class="py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 md:px-6 grid md:grid-cols-2 gap-6">
    <div class="bg-gradient-to-br from-brand-green to-emerald-500 text-white rounded-3xl p-8 md:p-10">
      <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center text-2xl mb-4">
        <i class="fa-solid fa-motorcycle"></i>
      </div>
      <h3 class="text-2xl md:text-3xl font-bold mb-2">Gabung Jadi Driver</h3>
      <p class="opacity-90 mb-5">Dapatkan penghasilan tambahan dengan jam kerja fleksibel.</p>
      <a href="/register" class="inline-block px-6 py-2.5 bg-white text-brand-green rounded-full font-bold hover:shadow-lg transition">
        Daftar Driver →
      </a>
    </div>
    <div class="bg-gradient-to-br from-brand-amber to-yellow-400 text-white rounded-3xl p-8 md:p-10">
      <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center text-2xl mb-4">
        <i class="fa-solid fa-store"></i>
      </div>
      <h3 class="text-2xl md:text-3xl font-bold mb-2">Daftarkan Toko Anda</h3>
      <p class="opacity-90 mb-5">Jangkau ribuan customer baru lewat platform Sampai-Kan.</p>
      <a href="/register" class="inline-block px-6 py-2.5 bg-white text-brand-amber rounded-full font-bold hover:shadow-lg transition">
        Daftar Merchant →
      </a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
