<% const pageTitle = 'Riwayat Pengantaran' %>
<%- include('../partials/header', { pageTitle }) %>
<%- include('../partials/nav-driver') %>

<section class="max-w-5xl mx-auto px-4 md:px-6 py-8 flex-1 w-full">
  <h1 class="text-2xl md:text-3xl font-bold mb-6">Riwayat Pengantaran</h1>

  <% if (orders.length === 0) { %>
    <div class="bg-white rounded-3xl p-12 text-center">
      <div class="w-24 h-24 mx-auto bg-primary-light rounded-full flex items-center justify-center text-brand-green">
        <i class="fa-solid fa-clock-rotate-left text-4xl"></i>
      </div>
      <h3 class="text-xl font-semibold mt-4">Belum ada pengantaran</h3>
      <p class="text-gray-500 mt-1">Selesaikan pesanan pertamamu untuk mulai membangun riwayat.</p>
    </div>
  <% } else { %>
    <div class="space-y-3">
      <% orders.forEach(order => { %>
        <div class="bg-white rounded-2xl p-5">
          <div class="flex items-start justify-between mb-2 flex-wrap gap-3">
            <div>
              <div class="flex items-center gap-2">
                <span class="font-bold">#<%= String(order.id).padStart(5, '0') %></span>
                <span class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-0.5 rounded-full bg-green-100 text-green-700">
                  <i class="fa-solid fa-check-circle"></i> Selesai
                </span>
              </div>
              <p class="text-xs text-gray-500 mt-1"><%= formatDate(order.updatedAt) %></p>
            </div>
            <div class="text-right">
              <div class="font-bold text-primary"><%= formatPrice(order.total) %></div>
              <div class="text-xs text-gray-500"><%= order.OrderItems.length %> item</div>
            </div>
          </div>
          <div class="text-sm text-gray-600 mt-2">
            <i class="fa-solid fa-user text-gray-400 mr-1"></i><%= order.Customer.fullName %> ·
            <i class="fa-solid fa-location-dot text-gray-400 ml-1 mr-1"></i><span class="line-clamp-1 inline"><%= order.address %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
